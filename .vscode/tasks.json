{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"command": "tools/bootstrap/python",
			"args": [
				"tools/translations/merge_ru_names.py",
				"tools/translations/ru_names_header.toml",
				"modular_ss220/translations/public/ru_names",
				"modular_ss220/translations/public/ru_names.toml"
			],
			"windows": {
				"command": ".\\tools\\bootstrap\\python.bat"
			},
			"problemMatcher": [],
			"label": "ru_names: compile translation"
		},
		{
			"type": "shell",
			"command": "tools/bootstrap/python",
			"args": [
				"tools/translations/split_ru_names.py",
				"--clean"
			],
			"windows": {
				"command": ".\\tools\\bootstrap\\python.bat"
			},
			"problemMatcher": [],
			"label": "ru_names: split translation"
		},
		{
			"type": "dreammaker",
			"dme": "${command:CurrentDME}",
			"problemMatcher": [
				"$dreammaker"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"label": "dm: build - ${command:CurrentDME}"
		},
		{
			"type": "shell",
			"command": ".\\tgui\\bin\\tgui.bat",
			"linux":{
				"command": "tgui/bin/tgui",
			},
			"problemMatcher": [
				"$tsc",
				"$eslint-stylish"
			],
			"group": "build",
			"label": "tgui: build"
		},
		{
			"type": "shell",
			"command": ".\\tgui\\bin\\tgui-dev-server.bat",
			"linux":{
				"command": "tgui/bin/tgui",
				"args": ["--dev"]
			},
			"problemMatcher": [
				"$tsc",
				"$eslint-stylish"
			],
			"group": "build",
			"label": "tgui: run dev server"
		}
	]
}
