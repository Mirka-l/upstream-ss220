{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"command": "tools/bootstrap/python",
			"args": [
				"tools/translations/merge_ru_names.py",
				"tools/translations/ru_names_header.toml",
				"modular_ss220/translations/public/ru_names",
				"modular_ss220/translations/public/ru_names.toml"
			],
			"windows": {
				"command": ".\\tools\\bootstrap\\python.bat"
			},
			"problemMatcher": [],
			"label": "ru_names: merge fragments"
		},
		{
			"type": "dreammaker",
			"dme": "${command:CurrentDME}",
			"problemMatcher": [
				"$dreammaker"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"label": "dm: build - ${command:CurrentDME}"
		},
		{
			"type": "dreammaker",
			"dme": "paradise.dme",
			"problemMatcher": [
				"$dreammaker"
			],
			"group": "build",
			"dependsOn": [
				"ru_names: merge fragments"
			],
			"label": "dm: build + TOML ru_names"
		},
		{
			"type": "shell",
			"command": ".\\tgui\\bin\\tgui.bat",
			"linux":{
				"command": "tgui/bin/tgui",
			},
			"problemMatcher": [
				"$tsc",
				"$eslint-stylish"
			],
			"group": "build",
			"label": "tgui: build"
		},
		{
			"type": "shell",
			"command": ".\\tgui\\bin\\tgui-dev-server.bat",
			"linux":{
				"command": "tgui/bin/tgui",
				"args": ["--dev"]
			},
			"problemMatcher": [
				"$tsc",
				"$eslint-stylish"
			],
			"group": "build",
			"label": "tgui: run dev server"
		},
		{
			"type": "shell",
			"command": ".\\tools\\translations\\new_ru_name_fragment.cmd",
			"args": ["${selectedText}"],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"focus": false,
				"showReuseMessage": false,
				"clear": false,
				"close": false
			},
			"problemMatcher": [],
			"label": "ru_names: new fragment from selection",
		}
	]
}
